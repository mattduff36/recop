# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.bak
recop.code-workspace

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env*.local
.env
template-setup.local.json
template-setup-checklist.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PWA files
**/public/sw.js
**/public/workbox-*.js
**/public/worker-*.js
**/public/sw.js.map
**/public/workbox-*.js.map
**/public/worker-*.js.map
build-output.txt
**/public/fallback-*.js
.cursor/debug*.log

# Lighthouse CI reports (generated artifacts)
.lighthouseci/

# Agent tools (generated by Cursor)
agent-tools/

# data folder (scanned forms and reference files)
/data

# database backups
/backups
/demo-snapshots

# private documentation and sensitive materials
/docs_private
/private/

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/

# Testsuite (generated state, reports, auth snapshots)
/testsuite/.state/
/testsuite/reports/

# Audit reports (screenshots and generated artifacts)
/reports/

# Supabase CLI temp cache
/supabase/.temp/
